package-as: PhDamage
manual-changelog: .release/CHANGELOG.md

externals:
  Libs/Ace3: https://repos.wowace.com/wow/ace3/trunk

ignore:
  - README.md
  - .github
  - .gitignore
  - .release
  - "*.md"
  - "!CHANGELOG.md"
  - .luacheckrc
  - tests
  - .release-please-manifest.json
  - release-please-config.json
